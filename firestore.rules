rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - role: string (required, ['admin', 'volunteer', 'guest'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             ((request.auth.token.email == "donakadriolli@gmail.com" || 
               request.auth.token.email == "vizioniRinoriShales@gmail.com" || 
               request.auth.token.email == "leotrimpajaziti17@gmail.com" ||
               request.auth.token.email == "admin@vizionirinorishales.org") ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /applications/{applicationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /staff/{staffId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidStaff(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidStaff(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string && data.role.size() > 0 && data.role.size() < 100 &&
             data.category is string && data.category.size() > 0 &&
             (data.bio == null || (data.bio is string && data.bio.size() < 1000)) &&
             (data.image == null || (data.image is string && data.image.size() < 2000000));
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
