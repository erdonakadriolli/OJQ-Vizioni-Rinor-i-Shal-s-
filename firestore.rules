rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - role: string (required, ['admin', 'volunteer', 'guest'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email in [
          "donakadriolli@gmail.com",
          "vizioniRinoriShales@gmail.com",
          "leotrimpajaziti17@gmail.com",
          "admin@vizionirinorishales.org"
        ] && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /applications/{applicationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /site_assets/{assetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /staff/{staffId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidStaff(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidStaff(data) {
      return hasRequiredFields(['name', 'role', 'category']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string && data.role.size() < 100 &&
             data.category is string && data.category.size() > 0 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 5000)) &&
             (!('image' in data) || (data.image is string && data.image.size() < 10000000)) &&
             (!('socials' in data) || data.socials is map);
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
